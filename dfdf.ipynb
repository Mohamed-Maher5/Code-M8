    "# Run API tests and compare\n",
    "\n",
    "from langchain_core.messages import SystemMessage, HumanMessage\n",
    "\n",
    "results = []\n",
    "\n",
    "for i, test in enumerate(test_cases):\n",
    "    print(f\"\\n{'='*60}\")\n",
    "    print(f\"Test {i+1}: {test['name']}\")\n",
    "    print(f\"{'='*60}\")\n",
    "    \n",
    "    # Build messages\n",
    "    messages = [\n",
    "        SystemMessage(content=CHAT_SYSTEM),\n",
    "        HumanMessage(content=test[\"prompt\"]),\n",
    "    ]\n",
    "    \n",
    "    # Estimate tokens before call\n",
    "    system_text = CHAT_SYSTEM\n",
    "    user_text = test[\"prompt\"]\n",
    "    \n",
    "    est_chars_div4 = estimate_chars_div4(system_text) + estimate_chars_div4(user_text)\n",
    "    est_tiktoken = estimate_tiktoken(system_text) + estimate_tiktoken(user_text)\n",
    "    \n",
    "    print(f\"User: {test['prompt']}\")\n",
    "    print(f\"Est tokens (÷4): {est_chars_div4}\")\n",
    "    print(f\"Est tokens (tiktoken): {est_tiktoken}\")\n",
    "    \n",
    "    # Make API call\n",
    "    response = llm.invoke(messages)\n",
    "    \n",
    "    # Get actual usage\n",
    "    usage = getattr(response, 'usage_metadata', {})\n",
    "    actual_input = usage.get('input_tokens', 0)\n",
    "    actual_output = usage.get('output_tokens', 0)\n",
    "    actual_total = usage.get('total_tokens', 0)\n",
    "    \n",
    "    print(f\"\\nActual from API:\")\n",
    "    print(f\"  Input:  {actual_input}\")\n",
    "    print(f\"  Output: {actual_output}\")\n",
    "    print(f\"  Total:  {actual_total}\")\n",
    "    \n",
    "    print(f\"\\nResponse: {response.content[:100]}...\")\n",
    "    \n",
    "    # Calculate estimation error\n",
    "    error_div4 = abs(actual_input - est_chars_div4) / actual_input * 100 if actual_input > 0 else 0\n",
    "    error_tiktoken = abs(actual_input - est_tiktoken) / actual_input * 100 if actual_input > 0 else 0\n",
    "    \n",
    "    print(f\"\\nEstimation Error:\")\n",
    "    print(f\"  ÷4 method:     {error_div4:.1f}% {'✓' if error_div4 < 20 else '✗'}\")\n",
    "    print(f\"  tiktoken:      {error_tiktoken:.1f}% {'✓' if error_tiktoken < 20 else '✗'}\")\n",
    "    \n",
    "    results.append({\n",
    "        \"name\": test[\"name\"],\n",
    "        \"prompt\": test[\"prompt\"],\n",
    "        \"response\": response.content,\n",
    "        \"est_div4\": est_chars_div4,\n",
    "        \"est_tiktoken\": est_tiktoken,\n",
    "        \"actual_input\": actual_input,\n",
    "        \"actual_output\": actual_output,\n",
    "        \"actual_total\": actual_total,\n",
    "        \"error_div4\": error_div4,\n",
    "        \"error_tiktoken\": error_tiktoken,\n",
    "    })"
   ]
  },
