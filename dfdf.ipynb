    "try:\n",
    "    from langchain_groq import ChatGroq\n",
    "    import tiktoken\n",
    "    print(\"✓ All dependencies available\")\n",
    "except ImportError as e:\n",
    "    print(f\"Installing missing: {e}\")\n",
    "    import subprocess\n",
    "    subprocess.run([\"pip\", \"install\", \"langchain-groq\", \"tiktoken\", \"openai\"])"
