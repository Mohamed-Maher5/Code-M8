    "avg_error_div4 = sum(r['error_div4'] for r in results) / len(results)\n",
    "avg_error_tiktoken = sum(r['error_tiktoken'] for r in results) / len(results)\n",
    "\n",
    "print(f\"\\nAverage Estimation Error:\")\n",
    "print(f\"  ÷4 method:     {avg_error_div4:.1f}%\")\n",
