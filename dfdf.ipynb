   "source": [
    "# Token Estimation Methods\n",
    "\n",
    "def estimate_chars_div4(text: str) -> int:\n",
    "    \"\"\"Method 1: Divide by 4 (Code-M8's current method)\"\"\"\n",
    "    return len(text) // 4\n",
    "\n",
    "def estimate_tiktoken(text: str, model: str = \"cl100k_base\") -> int:\n",
    "    \"\"\"Method 2: Use tiktoken tokenizer\"\"\"\n",
    "    enc = tiktoken.get_encoding(model)\n",
    "    return len(enc.encode(text))\n",
    "\n",
    "def estimate_tiktoken_gpt4(text: str) -> int:\n",
    "    \"\"\"Method 3: Use GPT-4 tokenizer via tiktoken\"\"\"\n",
    "    enc = tiktoken.encoding_for_model(\"gpt-4\")\n",
    "    return len(enc.encode(text))\n",
    "\n",
    "print(\"✓ Token estimation functions defined\")"
   ]
  },
