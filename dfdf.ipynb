    "\n",
    "GROQ_API_KEY = os.getenv(\"GROQ_API_KEY\")\n",
    "GROQ_MODEL = os.getenv(\"GROQ_MODEL\", \"qwen/qwen3-32b\")\n",
    "\n",
    "print(f\"API Key: {'✓ Set' if GROQ_API_KEY else '✗ Missing'}\")\n",
    "print(f\"Model: {GROQ_MODEL}\")"
   ]
